# ==========================================
# AI Travel Planner - Backend Environment
# ==========================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/travel_planner?schema=public"

# Redis (caching, BullMQ, express-rate-limit stores)
REDIS_URL="redis://localhost:6379"

# Better Auth Configuration
BETTER_AUTH_SECRET=your-super-secret-key-min-32-chars-long
# Issuer / internal API URL (server bind address is PORT). Used as fallback when CLIENT_URL is unset.
BETTER_AUTH_URL=http://localhost:5000
BETTER_AUTH_SESSION_TOKEN_EXPIRES_IN=86400
BETTER_AUTH_SESSION_TOKEN_UPDATE_AGE=43200

# Browser origin for the Next.js app (comma-separated for multiple origins). Used for OAuth base URL and CORS; set Google redirect URIs to {first_origin}/api/v1/auth/callback/google
CLIENT_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe Payments (checkout + webhook)
STRIPE_SECRET_KEY=sk_test_your_key
# Required in production for POST /api/v1/booking/webhook. In development, unsigned JSON webhooks are accepted with a console warning.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
# Optional overrides (defaults: gemini-2.5-flash / gemini-2.5-pro)
# GEMINI_FLASH_MODEL=gemini-2.5-flash
# GEMINI_PRO_MODEL=gemini-2.5-pro

# Sentry Error Tracking (optional)
SENTRY_DSN=https://your-sentry-dsn
